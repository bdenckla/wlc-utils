# Line-ending policy (see issue #50, supersedes #14):
#   - Git storage: LF for all text files.
#   - Workdir: LF everywhere, regardless of each clone's core.autocrlf/core.eol.
# Pinned here so the policy holds regardless of each clone's core.autocrlf/core.eol.

# text=auto keeps git's text/binary auto-detection; eol=lf forces LF in the workdir.
* text=auto eol=lf

# Binary assets: never convert.
*.png  binary
*.jpg  binary
*.woff2 binary
